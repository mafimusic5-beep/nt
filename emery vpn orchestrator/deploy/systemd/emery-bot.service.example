[Unit]
Description=Emery VPN Telegram Bot (aiogram)
After=network.target emery-backend.service

[Service]
Type=simple
User=emery
Group=emery
WorkingDirectory=/opt/emery_vpn_orchestrator
EnvironmentFile=/opt/emery_vpn_orchestrator/.env
ExecStart=/opt/emery_vpn_orchestrator/.venv/bin/python -m src.bot.main
Restart=always
RestartSec=5
TimeoutStopSec=15
StandardOutput=journal
StandardError=journal

[Install]
WantedBy=multi-user.target
